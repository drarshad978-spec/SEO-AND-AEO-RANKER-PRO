rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidSEOLog(data) {
      return data.keys().hasAll(['userId', 'action', 'input', 'result', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.action is string && data.action.size() <= 64 &&
             data.result is string && data.result.size() <= 1048576 && // 1MB limit check
             data.createdAt == request.time;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastActive']);
    }

    match /seoLogs/{logId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidSEOLog(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
