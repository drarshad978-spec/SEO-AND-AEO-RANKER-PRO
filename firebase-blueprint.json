{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user specific data and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "photoURL": { "type": "string", "description": "URL to the user's avatar" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the user first signed in" },
        "lastActive": { "type": "string", "format": "date-time", "description": "Last time the user was seen" },
        "brandVoice": {
          "type": "object",
          "properties": {
            "voice": { "type": "string" },
            "audience": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "SEOLog": {
      "title": "SEO Generation Log",
      "description": "History of SEO content generated by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the log" },
        "action": { "type": "string", "description": "The tool used" },
        "input": { "type": "object", "description": "The parameters passed to the tool" },
        "result": { "type": "string", "description": "The generated markdown result" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "input", "result", "createdAt"]
    },
    "Share": {
      "title": "Shared Report",
      "description": "Publicly shared SEO report",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "action": { "type": "string" }
      },
      "required": ["userId", "result", "createdAt", "action"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "seoLogs/{logId}": {
      "schema": "SEOLog",
      "description": "Collection of SEO generation history"
    },
    "shares/{shareId}": {
      "schema": "Share",
      "description": "Publicly shared SEO reports"
    }
  }
}
